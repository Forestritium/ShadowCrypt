# ShadowCrypt — Environment Configuration Template
# Copy this file to .env and fill in your Supabase project details.

# Your Supabase project URL  ->  Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key  ->  Settings > API > anon public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Internal app ID (optional)
VITE_APP_ID=your-app-id
